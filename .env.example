# Supabase - Phase 1
# Get these from: Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/Public key (safe for client-side, used for browser & server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only, for track/unsubscribe API routes)
# Get from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# App URL (for OAuth redirects and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail OAuth - from Google Cloud Console
# Create OAuth 2.0 credentials, add redirect: {NEXT_PUBLIC_APP_URL}/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
