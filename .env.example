# Supabase - Phase 1
# Get these from: Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon/Public key (safe for client-side, used for browser & server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (server-only, for track/unsubscribe API routes)
# Get from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ישירות ל-Postgres (אופציונלי) — להרצת מיגרציות מקומיות / סקריפטים
# מקור: Supabase → Project Settings → Database → Connection string (URI)
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# App URL (for OAuth redirects and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gmail OAuth - from Google Cloud Console
# Create OAuth 2.0 credentials, add redirect: {NEXT_PUBLIC_APP_URL}/api/auth/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Cron - secure the /api/cron/process-broadcasts endpoint
# Generate: openssl rand -hex 32
# Hobby plan: use cron-job.org → https://[YOUR-URL]/api/cron/process-broadcasts
# Header: Authorization: Bearer [CRON_SECRET], every 1 min
CRON_SECRET=

# Green API incoming webhook — query ?token=... on /api/whatsapp-webhook (must match)
WEBHOOK_SECRET=

# Gemini — powers AI email draft route (/api/email/ai-draft).
# Optional: if unset, the route returns 503 and the UI hides the AI button.
GEMINI_API_KEY=
