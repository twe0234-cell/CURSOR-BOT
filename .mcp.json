{
  "mcpServers": {
    "openai": {
      "command": "python3",
      "args": ["/home/user/CURSOR-BOT/scripts/openai_mcp_server.py"],
      "env": {
        "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY_HERE"
      }
    },
    "gemini": {
      "command": "python3",
      "args": ["/home/user/CURSOR-BOT/scripts/gemini_mcp_server.py"],
      "env": {
        "GEMINI_API_KEY": "YOUR_GEMINI_API_KEY_HERE"
      }
    },
    "filesystem": {
      "command": "mcp-server-filesystem",
      "args": [
        "/home/user/CURSOR-BOT",
        "/home/user",
        "/tmp"
      ]
    },
    "puppeteer": {
      "command": "mcp-server-puppeteer",
      "env": {
        "PUPPETEER_LAUNCH_ARGS": "--no-sandbox --disable-setuid-sandbox --disable-dev-shm-usage"
      }
    }
  }
}
